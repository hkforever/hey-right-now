{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Basic user identity information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "lastLogin": { "type": "number" }
      },
      "required": ["uid"]
    },
    "Plan": {
      "title": "Workout Plan",
      "description": "A reusable workout template",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "createdAt": { "type": "number" },
        "items": { "type": "array" },
        "sections": { "type": "array" }
      },
      "required": ["id", "title", "createdAt", "items"]
    },
    "WorkoutLog": {
      "title": "Workout Record",
      "description": "A completed workout session",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "planId": { "type": "string" },
        "title": { "type": "string" },
        "startTime": { "type": "number" },
        "endTime": { "type": "number" },
        "volume": { "type": "number" },
        "items": { "type": "array" },
        "sections": { "type": "array" }
      },
      "required": ["id", "title", "startTime", "items"]
    },
    "Exercise": {
      "title": "Exercise Definition",
      "description": "Configuration for a specific exercise",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string" },
        "equipment": { "type": "string" },
        "primaryMuscle": { "type": "string" },
        "secondaryMuscles": { "type": "array" },
        "isCustom": { "type": "boolean" },
        "media": { "type": "string" }
      },
      "required": ["id", "name", "type", "equipment", "primaryMuscle"]
    },
    "Settings": {
      "title": "User Settings",
      "description": "Global settings and persistent state like active workout",
      "type": "object",
      "properties": {
        "equipments": { "type": "array" },
        "muscles": { "type": "array" },
        "activeWorkout": { "type": "object" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/users/{userId}/plans/{planId}": {
      "schema": "Plan",
      "description": "User workout plans"
    },
    "/users/{userId}/history/{workoutId}": {
      "schema": "WorkoutLog",
      "description": "User workout history"
    },
    "/users/{userId}/customExercises/{exerciseId}": {
      "schema": "Exercise",
      "description": "User defined custom exercises"
    },
    "/users/{userId}/settings/{settingsId}": {
      "schema": "Settings",
      "description": "User specific settings and transient state"
    }
  }
}
